/** Global styles for 程序员口袋 */

page,
.page {
  background: #F5F5F7;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

/* ===== 全局 ===== */

.primary {
  color: #007AFF;
}

.muted {
  color: #8E8E93;
}

/* ===== 布局 ===== */

.container {
  padding: 0 24rpx;
}

.header {
  padding: 32rpx 24rpx 16rpx;
}

.title {
  font-size: 48rpx;
  margin: 8rpx;
  font-weight: 512;
  color: #111;
}

.subtitle {
  margin: 8rpx;
  font-size: 32rpx;
  color: #6E6E73;
}

/* ===== 液态玻璃 ===== */

.glass-card {
  position: relative;

  overflow: hidden;

  border-radius: 32rpx;

  background:
    linear-gradient(135deg,
      rgba(255, 255, 255, .72),
      rgba(255, 255, 255, .45));

  backdrop-filter: blur(40px);

  border: 1rpx solid rgba(255, 255, 255, .65);

  box-shadow:
    0 12rpx 40rpx rgba(0, 0, 0, .08),
    inset 0 1rpx 0 rgba(255, 255, 255, .95),
    inset 0 -1rpx 0 rgba(255, 255, 255, .2);
}

.glass-card::before {
  content: '';

  position: absolute;

  top: -40%;
  left: -20%;

  width: 140%;
  height: 80%;

  background:
    radial-gradient(ellipse at center,
      rgba(255, 255, 255, .45),
      transparent 70%);

  pointer-events: none;
}

/* ===== 搜索框 ===== */

.search-pill {
  display: flex;
  align-items: center;

  height: 88rpx;

  padding: 0 24rpx;

  border-radius: 999rpx;

  background: rgba(255, 255, 255, .75);

  backdrop-filter: blur(16px);

  border: 1rpx solid rgba(255, 255, 255, .8);

  box-shadow:
    0 4rpx 16rpx rgba(0, 0, 0, .04);
}

/* ===== 工具网格 ===== */

.grid {
  display: grid;

  grid-template-columns: repeat(4, 1fr);

  row-gap: 42rpx;

  margin-top: 32rpx;

  padding-bottom: 180rpx;
}

.grid-item {
  display: flex;
  justify-content: center;
  align-items: center;
}

/* ===== 工具卡片 ===== */

.tool-card {
  width: 140rpx;

  display: flex;
  flex-direction: column;

  align-items: center;
}

.tool-card:active {
  transform: scale(0.95);
}

.tool-icon {
  width: 96rpx;
  height: 96rpx;

  display: flex;
  align-items: center;
  justify-content: center;

  font-size: 44rpx;

  border-radius: 24rpx;

  background: rgba(255, 255, 255, .85);

  border: 1rpx solid rgba(255, 255, 255, .9);

  box-shadow:
    0 6rpx 18rpx rgba(0, 0, 0, .05);

  backdrop-filter: blur(16px);
}

.tool-name {
  width: 140rpx;

  margin-top: 12rpx;

  font-size: 24rpx;
  line-height: 1.35;

  text-align: center;

  color: #1D1D1F;

  word-break: break-all;
}

/* ===== 按钮 ===== */

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;

  padding: 12rpx 24rpx;

  background: #FFF;

  border-radius: 999rpx;

  box-shadow:
    0 4rpx 12rpx rgba(0, 0, 0, .05);
}

/* ===== 分区标题 ===== */

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111;
}