<view class="page">

  <!-- 用户信息 -->
  <view class="profile-header">

    <view class="avatar-wrap">
      <image
        wx:if="{{!imgError}}"
        src="/assets/logo.png"
        mode="aspectFill"
        class="avatar"
        binderror="onImgError"
      />

      <view wx:else class="avatar-fallback">
        P
      </view>
    </view>

    <view class="profile-name">
      程序员口袋
    </view>

    <view class="profile-version">
      Version 1.0.0
    </view>

  </view>

  <!-- 菜单 -->
  <view class="container">

    <view class="glass-card menu-card">

      <view class="menu-item" bindtap="onAbout">
        <text>关于我们</text>
        <text class="arrow">›</text>
      </view>

      <view class="divider"></view>

      <view class="menu-item" bindtap="onFeedback">
        <text>意见反馈</text>
        <text class="arrow">›</text>
      </view>

      <view class="divider"></view>

      <view class="menu-item" bindtap="onShare">
        <text>分享小程序</text>
        <text class="arrow">›</text>
      </view>

    </view>

    <view class="footer">
      <view>程序员口袋</view>
      <view>© 2026 DevPocket</view>
    </view>

  </view>

</view>