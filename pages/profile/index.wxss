.profile-header {
  display: flex;
  flex-direction: column;

  align-items: center;

  padding-top: 40rpx;
  padding-bottom: 40rpx;
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;

  border-radius: 60rpx;

  overflow: hidden;

  background: #fff;

  box-shadow:
    0 8rpx 24rpx rgba(0,0,0,.08);
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  width: 100%;
  height: 100%;

  display: flex;
  align-items: center;
  justify-content: center;

  background: #007AFF;

  color: #fff;

  font-size: 56rpx;
  font-weight: 700;
}

.profile-name {
  margin-top: 20rpx;

  font-size: 44rpx;
  font-weight: 700;

  color: #111;
}

.profile-version {
  margin-top: 8rpx;

  font-size: 24rpx;

  color: #8E8E93;
}

.menu-card {
  overflow: hidden;
  padding: 0;
}

.menu-item {
  height: 100rpx;

  padding: 0 28rpx;

  display: flex;
  align-items: center;
  justify-content: space-between;

  font-size: 30rpx;

  color: #111;

  background: transparent;
  border: none;
}

.menu-item::after {
  display: none;
}

.share-btn {
  margin: 0;
  padding: 0 28rpx;

  line-height: normal;

  background: transparent;
  border: none;

  text-align: left;
}

.share-btn::after {
  display: none;
}

.arrow {
  font-size: 40rpx;
  color: #C7C7CC;
}

.divider {
  height: 1rpx;

  background: rgba(0,0,0,.06);

  margin-left: 28rpx;
}

.footer {
  margin-top: 80rpx;

  text-align: center;

  font-size: 24rpx;
  line-height: 1.8;

  color: #8E8E93;
}