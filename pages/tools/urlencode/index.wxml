<view class="page container">
  <view class="header">
    <view class="title">URL 编码</view>
    <view class="subtitle">编码/解码 URL 组件</view>
  </view>
  <view class="container">
    <textarea placeholder="输入文本/URL片段" bindinput="onInput" value="{{input}}"></textarea>
    <view style="height:12rpx"></view>
    <view class="row">
      <button data-mode="encode" bindtap="setMode" class="{{mode==='encode'? 'btn active':'btn'}}">编码</button>
      <button data-mode="decode" bindtap="setMode" class="{{mode==='decode'? 'btn active':'btn'}}">解码</button>
    </view>
    <view style="height:12rpx"></view>
    <button bindtap="run">执行</button>
    <view style="height:12rpx"></view>
    <textarea readonly value="{{output}}"></textarea>
    <view style="height:12rpx"></view>
    <button bindtap="copyOutput">复制结果</button>
  </view>
</view>
