<view class="page container">
  <view class="header">
    <view class="title">Prompt 优化</view>
    <view class="subtitle">基于规则的离线提示优化建议（示例）</view>
  </view>
  <view class="container">
    <textarea placeholder="输入原始 Prompt" bindinput="onInput" value="{{input}}"></textarea>
    <view style="height:12rpx"></view>
    <button bindtap="optimize">优化</button>
    <view style="height:12rpx"></view>
    <textarea readonly value="{{output}}"></textarea>
    <view style="height:12rpx"></view>
    <button bindtap="copy">复制优化结果</button>
  </view>
</view>
