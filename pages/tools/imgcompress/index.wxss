.card {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.preview {
  width: 100%;
  border-radius: 20rpx;
  margin-top: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  font-size: 26rpx;
}

.primary-btn {
  background: #007AFF;
  color: #fff;
  border-radius: 999rpx;
}

.compress-btn {
  margin-top: 32rpx;
}

.hidden-canvas {
  width: 1px;
  height: 1px;
  position: fixed;
  left: -9999px;
}

/* 压缩率 */



.quality-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.quality-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #007AFF;
}

.quality-desc {
  display: flex;
  justify-content: space-between;
}

.quality-tag {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,.6);
  color: #666;
  font-size: 22rpx;
}

.quality-tag.active {
  background: #007AFF;
  color: #fff;
}

.estimate {
  margin-top: 20rpx;
  color: #666;
  font-size: 24rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 28rpx;
}