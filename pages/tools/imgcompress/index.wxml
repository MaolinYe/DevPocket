<view class="page container">
  <view class="header">
    <view class="title">图片压缩</view>
    <view class="subtitle">选择图片并按目标分辨率压缩，支持保存到相册</view>
  </view>

  <view class="container">
    <button bindtap="chooseImage">选择图片</button>
    <view style="height:12rpx"></view>
    <view class="row">
      <input placeholder="目标宽 (px)" bindinput="onWidth" type="number" value="{{targetW}}" />
      <input placeholder="目标高 (px)" bindinput="onHeight" type="number" value="{{targetH}}" />
    </view>
    <view style="height:12rpx"></view>
    <button bindtap="compress" class="btn">开始压缩</button>
    <view style="height:12rpx"></view>
    <image wx:if="{{preview}}" src="{{preview}}" mode="widthFix" style="max-width:100%;border-radius:12rpx" />
    <view style="height:12rpx"></view>
    <button wx:if="{{preview}}" bindtap="saveImage">保存到相册</button>
  </view>

  <canvas canvas-id="compressCanvas" style="width:300px;height:300px;display:none"></canvas>
</view>
