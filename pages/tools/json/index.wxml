<view class="page">
  <view class="header container">
    <view class="title">JSON格式化</view>
    <view class="subtitle">输入 JSON 后点击格式化或压缩</view>
  </view>
  <view class="container">
    <textarea value="{{input}}" bindinput="onInput" placeholder="输入或粘贴 JSON" style="height:320rpx;padding:18rpx" class="glass-card"></textarea>
    <view style="height:18rpx"></view>
    <view style="display:flex; gap:12rpx">
      <button bindtap="formatJson" class="btn">格式化</button>
      <button bindtap="minifyJson" class="btn">压缩</button>
      <button bindtap="copyOutput" class="btn">复制结果</button>
    </view>
    <view style="height:18rpx"></view>
    <textarea readonly value="{{output}}" style="height:200rpx;padding:18rpx" class="glass-card"></textarea>
  </view>
</view>
