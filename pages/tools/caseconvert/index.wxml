<view class="page container">
  <view class="header">
    <view class="title">大小写转换</view>
  </view>
  <view class="container">
    <textarea placeholder="输入文本" bindinput="onInput" value="{{input}}"></textarea>
    <view style="height:12rpx"></view>
    <button data-mode="upper" bindtap="convert">转大写</button>
    <button data-mode="lower" bindtap="convert">转小写</button>
    <button data-mode="title" bindtap="convert">首字母大写</button>
    <view style="height:12rpx"></view>
    <textarea readonly value="{{output}}"></textarea>
    <view style="height:12rpx"></view>
    <button bindtap="copy">复制结果</button>
  </view>
</view>
