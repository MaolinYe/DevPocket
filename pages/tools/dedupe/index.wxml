<view class="page container">
  <view class="header">
    <view class="title">文本去重</view>
  </view>
  <view class="container">
    <textarea placeholder="每行一条，支持整段粘贴" bindinput="onInput" value="{{input}}"></textarea>
    <view style="height:12rpx"></view>
    <button bindtap="run">去重</button>
    <view style="height:12rpx"></view>
    <textarea readonly value="{{output}}"></textarea>
    <view style="height:12rpx"></view>
    <button bindtap="copy">复制结果</button>
  </view>
</view>
