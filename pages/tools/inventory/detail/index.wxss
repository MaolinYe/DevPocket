.cover {
	width: 100%;
	height: 360rpx;
	border-radius: 20rpx;
	margin-bottom: 20rpx;
}

.title {
	font-size: 34rpx;
	font-weight: 600;
	margin-top: 12rpx;
}

.meta {
	color: #8e8e93;
	margin: 8rpx;
	font-size: 24rpx;
}

.remark {
	margin: 8rpx;
	font-size: 26rpx;
	line-height: 1.6;
	color: #111;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.icon-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  font-size: 36rpx;
}

.edit-btn {
  background: #007AFF;
}

.delete-btn {
  background: #ff3b30;
}