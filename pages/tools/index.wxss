.header {
  padding-bottom: 12rpx;
}

.search-pill input {
  flex: 1;
  height: 36rpx;
  font-size: 26rpx;
  border: 0;
  padding: 0;
}

/* 工具区域 */
.grid {
  margin-top: 24rpx;

  display: grid;

  grid-template-columns: repeat(4, 1fr);

  column-gap: 8rpx;
  row-gap: 32rpx;

  padding: 0 8rpx 180rpx;
}

.grid-item {
  display: flex;
  justify-content: center;
}

.item-card {
  background: rgba(255, 255, 255, .72);
  backdrop-filter: blur(24rpx);
  border: 1rpx solid rgba(255, 255, 255, .6);
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, .06);
  border-radius: 22rpx;
  overflow: hidden;
  transition: .2s;
}

.item-card:active {
  transform: scale(.97);
}

.cover {
  border-radius: 22rpx 22rpx 0 0;
}